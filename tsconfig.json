{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "app/addmission/page.tsx",
    "app/billing/page.tsx",
    "app/doctors/page.tsx",
    "app/lab/page.tsx",
    "app/inpatient/page.tsx",
    "app/medicine/page.tsx",
    "app/outpatient/page.tsx",
    "app/patients/page.tsx",
    "app/recipts/page.tsx",
    "app/rmp/page.tsx",
    "app/surgery/page.tsx",
    "app/xray/page.tsx",
    "app/page.tsx",
    "next.config.js",
    "out/types/**/*.ts",
    "out/dev/types/**/*.ts"
, "app/dashboard/labreport"  ],
  "exclude": [
    "node_modules"
  ]
}
